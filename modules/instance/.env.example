# Server Environment Variables

# Server Configuration
PORT=4150
NODE_ENV=development

# Instance Identity
INSTANCE_NAME=My Stellarity Instance
INSTANCE_PUBLIC=false
INSTANCE_DATA_DIR=./data

# Central Server
CENTRAL_SERVER_URL=http://localhost:3001

# Redis Configuration (leave empty to use in-memory fallback — fine for dev)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Encryption Keys (AES-256-GCM)
ENCRYPTION_KEY=your-32-byte-encryption-key-here!
VOICE_ENCRYPTION_KEY=your-voice-encryption-key-32bytes

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Voice Server Configuration
VOICE_MAX_USERS_PER_CHANNEL=50
VOICE_BITRATE=64000
