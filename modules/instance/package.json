{
  "name": "@stellarity/instance",
  "version": "1.0.0",
  "description": "Stellarity Instance Server - Self-hosted community server with voice, messaging, and channels",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "tsc && bun run build:panel",
    "build:panel": "cd panel && bunx --bun vite build",
    "start": "bun run src/index.ts",
    "db:migrate": "bun run src/database/migrate.ts",
    "setup": "bun run src/setup.ts",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stellarity/shared": "1.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.0",
    "socket.io": "^4.7.2",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.4",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
}
