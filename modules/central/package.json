{
  "name": "@stellarity/central",
  "version": "1.0.0",
  "description": "Stellarity Central Server - User accounts, discovery, DMs, and subscriptions",
  "main": "dist/index.js",
  "scripts": {
    "dev": "bun --watch run src/index.ts",
    "build": "tsc",
    "start": "bun run src/index.ts",
    "db:migrate": "bun run src/database/migrate.ts",
    "seed:admin": "bun run src/database/seed-admin.ts",
    "setup": "bun run src/setup.ts",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stellarity/shared": "1.0.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jose": "^5.2.0",
    "otplib": "^12.0.1",
    "pg": "^8.11.3",
    "qrcode": "^1.5.3",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/qrcode": "^1.5.5",
    "@types/uuid": "^9.0.7",
    "@types/bun": "latest",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.3"
  }
}
