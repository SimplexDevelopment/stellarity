[Unit]
Description=Stellarity Central Server
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=simple
User=stellarity
WorkingDirectory=/home/stellarity/stellarity/modules/central
ExecStart=/home/stellarity/.bun/bin/bun run src/index.ts
Restart=always
RestartSec=5
Environment=NODE_ENV=production

[Install]
WantedBy=multi-user.target
